---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  decoding?: 'async' | 'sync' | 'auto';
}

const {
  src,
  alt,
  width,
  height,
  sizes,
  loading = 'lazy',
  fetchpriority,
  class: className = '',
  decoding = 'async',
} = Astro.props;
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  sizes={sizes}
  loading={loading}
  fetchpriority={fetchpriority}
  decoding={decoding}
  class={className}
/>
