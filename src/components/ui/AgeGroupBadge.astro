---
interface Props {
  label: string;
  ages: string;
  emoji: string;
}

const { label, ages, emoji } = Astro.props;
---

<div class="flex flex-col items-center gap-2 rounded-lg bg-white/10 px-4 py-3 text-center backdrop-blur-sm">
  <span class="text-3xl" aria-hidden="true">{emoji}</span>
  <span class="display-md text-white">{label}</span>
  <span class="text-sm text-white/80">{ages}</span>
</div>
