---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit';
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  target,
  rel,
  class: className = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center rounded-md font-semibold uppercase tracking-wide transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red';

const variants = {
  primary: 'bg-red text-white hover:bg-red-dark',
  secondary:
    'border-2 border-white bg-transparent text-white hover:bg-white hover:text-navy',
  ghost: 'bg-transparent text-red hover:bg-red/10',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes} target={target} rel={rel}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
