---
interface Props {
  title: string;
  year: number;
  cover: string;
  images: string[];
}

const { title, year, cover, images } = Astro.props;
---

<div class="space-y-8">
  <header class="border-b-4 border-navy pb-6">
    <h1 class="marker-lg text-navy">{title}</h1>
    <p class="mt-2 text-grey">{year}</p>
  </header>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      images.map((src) => (
        <figure class="overflow-hidden border-4 border-navy bg-white shadow-md">
          <img
            src={src}
            alt={`${title} — photo`}
            class="aspect-[4/3] w-full object-cover"
            loading="lazy"
          />
        </figure>
      ))
    }
  </div>

  {
    images.length === 0 && (
      <p class="text-center text-grey">Aucune photo dans cet album pour le moment.</p>
    )
  }
</div>
