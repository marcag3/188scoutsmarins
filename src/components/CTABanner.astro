---
import Button from './ui/Button.astro';

interface Props {
  href?: string;
  buttonLabel?: string;
}

const {
  href = '/a-propos/inscription/',
  buttonLabel = "S'inscrire",
} = Astro.props;
---

<aside class="bg-red text-white">
  <div class="mx-auto max-w-6xl px-4 py-8 md:px-6">
    <div class="flex flex-col items-center gap-6 text-center md:flex-row md:items-center md:justify-between md:gap-8 md:text-left">
      <div class="max-w-2xl">
        <p class="tagline-serif">
          Et puis&hellip; <span class="font-semibold not-italic text-navy">Embarques-tu?</span>
        </p>
        <p class="mt-3 text-sm leading-relaxed text-white/90 md:text-base">
          Inscriptions en cours — rejoins la troupe pour une saison d'aventures nautiques et
          scoutistes, des activités hors du commun à la hauteur de tes ambitions.
        </p>
      </div>
      <Button href={href} variant="secondary" class="shrink-0">{buttonLabel}</Button>
    </div>
  </div>
</aside>
