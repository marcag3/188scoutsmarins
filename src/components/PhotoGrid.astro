---
interface Album {
  title: string;
  year: number;
  cover: string;
  href: string;
}

interface Props {
  albums: Album[];
}

const { albums } = Astro.props;
---

<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {
    albums.map((album) => (
      <a href={album.href} class="group block overflow-hidden border-4 border-navy bg-white shadow-md transition hover:shadow-lg">
        <div class="aspect-[4/3] overflow-hidden">
          <img
            src={album.cover}
            alt={album.title}
            class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-4">
          <h3 class="marker-md text-navy">{album.title}</h3>
          <p class="text-sm text-grey">{album.year}</p>
        </div>
      </a>
    ))
  }
</div>
