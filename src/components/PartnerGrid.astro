---
import OptimizedImg from './ui/OptimizedImg.astro';

interface Partner {
  name: string;
  logo?: string;
  href?: string;
  color?: boolean;
}

interface Props {
  partners: Partner[];
}

const { partners } = Astro.props;
---

<div class="flex flex-wrap items-center justify-center gap-8">
  {
    partners.map((partner) => {
      const content = partner.logo ? (
        <OptimizedImg
          src={partner.logo}
          alt={partner.name}
          class:list={[
            'max-h-16 max-w-[140px] object-contain',
            !partner.color && 'grayscale transition hover:grayscale-0',
          ]}
          loading="lazy"
          width={140}
          height={64}
        />
      ) : (
        <span class="display-md text-navy/60">{partner.name}</span>
      );

      return partner.href ? (
        <a href={partner.href} target="_blank" rel="noopener noreferrer" class="block">
          {content}
        </a>
      ) : (
        <div>{content}</div>
      );
    })
  }
</div>
