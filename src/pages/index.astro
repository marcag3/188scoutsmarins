---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/ui/Section.astro';
import InfoBox from '../components/ui/InfoBox.astro';
import RedRule from '../components/ui/RedRule.astro';
import CalendarEmbed from '../components/CalendarEmbed.astro';
import general from '../content/settings/general.json';
import { site } from '../data/site';
---

<BaseLayout description={general.tagline}>
  <Hero />

  <Section variant="light">
    <div class="mx-auto max-w-3xl space-y-6">
      <h2 class="marker-lg text-center text-navy">Notre mission</h2>
      <RedRule class="max-w-xs mx-auto" />
      <div class="prose-scout text-center">
        <p>
          Ceux qui souhaitent rencontrer des gens, créer des liens, réaliser des projets
          positifs, développer leur autonomie ou simplement avoir du plaisir en équipe, se
          retrouvent dans notre scoutisme marin.
        </p>
      </div>
      <div class="flex justify-center gap-4 pt-4">
        <InfoBox class="max-w-xs">
          <p class="label-caps">Louveteaux</p>
          <p class="mt-1 font-bold">9 – 11 ans</p>
        </InfoBox>
        <InfoBox class="max-w-xs">
          <p class="label-caps">Éclaireurs</p>
          <p class="mt-1 font-bold">12 – 17 ans</p>
        </InfoBox>
      </div>
    </div>
  </Section>

  <RedRule />

  <Section variant="sand">
    <h2 class="marker-lg mb-6 text-center text-navy">Prochaines activités</h2>
    <CalendarEmbed src={general.calendarEmbedUrl} />
  </Section>

  <div class="bg-navy py-6 text-center">
    <a href="/a-propos/inscription-2/" class="info-box inline-block min-w-64 transition hover:bg-sand">
      <p class="text-lg font-bold uppercase tracking-wide text-navy">Inscriptions en cours</p>
    </a>
    <p class="mt-4 text-sm text-white/80">{site.meetingInfo}</p>
  </div>
</BaseLayout>
