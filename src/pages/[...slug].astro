---
import { getCollection, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import CalendarEmbed from '../components/CalendarEmbed.astro';
import PartnerGrid from '../components/PartnerGrid.astro';
import general from '../content/settings/general.json';
import { partners } from '../data/partners';
import { getPageSlugParam } from '../lib/content';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);

  return pages.map((page) => ({
    params: { slug: getPageSlugParam(page) },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
const { title, description, layout } = page.data;

---

<PageLayout title={title} description={description}>
  {layout === 'contact' && (
    <div
      id="contact-success"
      class="not-prose mb-8 hidden rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900"
      role="status"
    >
      Merci! Votre message a été envoyé. Nous vous répondrons dès que possible.
    </div>
    <script is:inline>
      if (new URLSearchParams(window.location.search).get('sent') === '1') {
        document.getElementById('contact-success')?.classList.remove('hidden');
      }
    </script>
  )}

  <Content />

  {layout === 'contact' && (
    <div class="not-prose mt-10">
      <ContactForm />
    </div>
  )}

  {layout === 'calendar' && (
    <div class="not-prose mt-10">
      <CalendarEmbed src={general.calendarEmbedUrl} />
    </div>
  )}

  {layout === 'partners' && (
    <div class="not-prose mt-10">
      <PartnerGrid partners={partners} />
    </div>
  )}
</PageLayout>
